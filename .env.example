# Agent Runtime Kit environment template
# Usage: cp .env.example .env, then edit local values.
# Never commit .env or real API keys.

# Core daemon
AGENTRT_HOST=127.0.0.1
AGENTRT_PORT=7437

# Logging
AGENTRT_LOG_LEVEL=INFO
# Leave empty to log to stderr only.
AGENTRT_LOG_FILE=~/.agentrt/logs/core.log
# text or json
AGENTRT_LOG_FORMAT=text

# Optional config file override
# AGENTRT_CONFIG=~/.agentrt/config.toml

# LLM provider
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# AGENTRT_LLM_DEFAULT_MODEL=claude-sonnet-4-6
# AGENTRT_MAX_STEPS=20
